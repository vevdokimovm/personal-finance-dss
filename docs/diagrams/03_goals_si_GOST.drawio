<mxfile host="app.diagrams.net" type="device">
  <diagram name="Взвешенная обеспеченность Si (ГОСТ 19.701-90)" id="goals-si">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1150" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="start" value="Начало&#10;calculate_goals_si" style="rounded=1;whiteSpace=wrap;html=1;arcSize=40;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="20" width="220" height="50" as="geometry" />
        </mxCell>

        <mxCell id="input" value="Ввод: сумма на цели x_goals,&#10;список целей G, дата today" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="300" y="100" width="240" height="60" as="geometry" />
        </mxCell>

        <mxCell id="dec_zero" value="x_goals ≤ 0&#10;или G пуст ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="345" y="190" width="150" height="90" as="geometry" />
        </mxCell>

        <mxCell id="ret0" value="Вернуть Si = 0,&#10;allocation = {}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="200" width="190" height="60" as="geometry" />
        </mxCell>

        <!-- Обогащение -->
        <mxCell id="loop1" value="Для каждой цели s c остатком &gt; 0:&#10;urgency = max(1, 12 / месяцев_до_дедлайна)&#10;weight = вес категории ks&#10;priority = weight · urgency" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="270" y="310" width="300" height="80" as="geometry" />
        </mxCell>

        <mxCell id="total" value="total_priority = Σ priority по целям" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="285" y="420" width="270" height="50" as="geometry" />
        </mxCell>

        <mxCell id="dec_tot" value="total_priority ≤ 0 ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="345" y="500" width="150" height="80" as="geometry" />
        </mxCell>

        <mxCell id="ret0b" value="Вернуть Si = 0,&#10;allocation = {}" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="510" width="190" height="60" as="geometry" />
        </mxCell>

        <!-- Цикл распределения -->
        <mxCell id="loop2" value="Для каждой цели s:&#10;share = priority_s / total_priority&#10;x_s = min(x_goals · share, остаток_s)&#10;allocation[s] = x_s&#10;weighted_x += x_s · priority_s&#10;weighted_total += остаток_s · priority_s" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="270" y="610" width="300" height="110" as="geometry" />
        </mxCell>

        <mxCell id="si" value="Si = min( weighted_x / weighted_total , 1.0 )" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="285" y="760" width="270" height="50" as="geometry" />
        </mxCell>

        <mxCell id="output" value="Вывод: Si, allocation {цель → сумма}" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="290" y="850" width="250" height="60" as="geometry" />
        </mxCell>

        <mxCell id="end" value="Конец" style="rounded=1;whiteSpace=wrap;html=1;arcSize=40;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="345" y="950" width="160" height="50" as="geometry" />
        </mxCell>

        <!-- Стрелки -->
        <mxCell id="b1" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="start" target="input"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="b2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="input" target="dec_zero"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="b3" value="Да" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=11;" edge="1" parent="1" source="dec_zero" target="ret0"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="b3b" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="ret0" target="end"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="695" y="975" /></Array></mxGeometry></mxCell>
        <mxCell id="b4" value="Нет" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=11;" edge="1" parent="1" source="dec_zero" target="loop1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="b5" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="loop1" target="total"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="b6" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="total" target="dec_tot"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="b7" value="Да" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=11;" edge="1" parent="1" source="dec_tot" target="ret0b"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="b7b" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="ret0b" target="end"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="695" y="975" /></Array></mxGeometry></mxCell>
        <mxCell id="b8" value="Нет" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=11;" edge="1" parent="1" source="dec_tot" target="loop2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="b9" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="loop2" target="si"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="b10" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="si" target="output"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="b11" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="output" target="end"><mxGeometry relative="1" as="geometry" /></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
</mxfile>
