        <mxCell id="d27_st1" value="1. Идея / гипотеза&#10;&#10;Проблема пользователя,&#10;гипотеза ценности" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
