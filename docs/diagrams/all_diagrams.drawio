        <mxCell id="d20_d_t" value="DEFINE" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#1a3a5c;" vertex="1" parent="1">
          <mxGeometry x="85" y="135" width="160" height="25" as="geometry" />
        </mxCell>
        <mxCell id="d20_d_d" value="Определить проблему:&#10;высокая долговая нагрузка,&#10;нет резерва, цели не движутся" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="85" y="220" width="220" height="60" as="geometry" />
        </mxCell>

        
        <mxCell id="d20_m" style="shape=mxgraph.arrows2.arrow;dy=0.6;dx=40;notch=40;html=1;fillColor=#d5e8d4;strokeColor=#82b366;" vertex="1" parent="1">
          <mxGeometry x="290" y="120" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d20_m_t" value="MEASURE" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#2d5016;" vertex="1" parent="1">
          <mxGeometry x="335" y="135" width="160" height="25" as="geometry" />
        </mxCell>
        <mxCell id="d20_m_d" value="Измерить показатели:&#10;Rt, Lt (ликвидность),&#10;Dt (долг/доход), BLR, CFt" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
