          <mxGeometry x="750" y="120" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d20_i_t" value="IMPROVE" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#8a5a00;" vertex="1" parent="1">
          <mxGeometry x="795" y="135" width="160" height="25" as="geometry" />
        </mxCell>
        <mxCell id="d20_i_d" value="Внедрить лучшую a*:&#10;ранжирование по SAW,&#10;исполнить распределение Rt" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
          <mxGeometry x="795" y="220" width="220" height="60" as="geometry" />
