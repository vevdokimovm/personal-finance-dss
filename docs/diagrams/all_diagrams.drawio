<diagram name="State Machine — жизненный цикл альтернативы" id="state-machine">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="950" pageHeight="850" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="d09_title" value="FINPILOT — Жизненный цикл альтернативы (UML State Machine)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="230" y="15" width="500" height="30" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_init" style="ellipse;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="445" y="70" width="24" height="24" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_s_gen" value="Generated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="385" y="130" width="150" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_s_eval" value="Evaluated" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=13;fontStyle=1;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="385" y="240" width="150" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_s_adm" value="Admissible" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="385" y="360" width="150" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_s_rej" value="Rejected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=13;fontStyle=1;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="680" y="240" width="150" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_s_rank" value="Ranked" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="385" y="480" width="150" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_s_rec" value="Recommended" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="250" y="590" width="150" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_s_not" value="NotSelected" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=13;fontStyle=1;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="520" y="590" width="150" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_s_exp" value="Explained" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=13;fontStyle=1;arcSize=30;" vertex="1" parent="1">
          <mxGeometry x="250" y="690" width="150" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_final" style="ellipse;html=1;fillColor=#ffffff;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="448" y="780" width="28" height="28" as="geometry" />
        </mxCell>
        <mxCell id="d09_final_inner" style="ellipse;html=1;fillColor=#000000;strokeColor=#000000;" vertex="1" parent="1">
          <mxGeometry x="454" y="786" width="16" height="16" as="geometry" />
        </mxCell>

        
        <mxCell id="d09_t0" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="d09_init" target="d09_s_gen"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d09_t1" value="evaluate_alternative()&#10;Avalanche + Si + пересчёт Rt'/Lt'/Dt'" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="d09_s_gen" target="d09_s_eval"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d09_t2" value="проходит фильтр&#10;Rt'≥0 ∧ Lt'≥Lmin ∧ Dt'≤Dmax" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="d09_s_eval" target="d09_s_adm"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d09_t3" value="нарушено&#10;ограничение" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="d09_s_eval" target="d09_s_rej"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d09_t4" value="rank_alternatives()&#10;расчёт U(a) по SAW" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="d09_s_adm" target="d09_s_rank"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d09_t5" value="U(a) максимальна&#10;(a* первая)" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="d09_s_rank" target="d09_s_rec"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d09_t6" value="U(a) не&#10;максимальна" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="d09_s_rank" target="d09_s_not"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d09_t7" value="explain_alternative()&#10;gains / costs / insight" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="d09_s_rec" target="d09_s_exp"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d09_t8" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="d09_s_exp" target="d09_final"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="325" y="794" /></Array></mxGeometry></mxCell>
        <mxCell id="d09_t9" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="d09_s_not" target="d09_final"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="595" y="794" /></Array></mxGeometry></mxCell>
        <mxCell id="d09_t10" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;" edge="1" parent="1" source="d09_s_rej" target="d09_final"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="880" y="794" /><mxPoint x="476" y="794" /></Array></mxGeometry></mxCell>

      </root>
    </mxGraphModel>
