        <mxCell id="1" parent="0" />

        <mxCell id="d20_title" value="FINPILOT — Методология DMAIC (Six Sigma) применительно к финансовому здоровью" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1">
