          <mxGeometry x="1025" y="135" width="160" height="25" as="geometry" />
        </mxCell>
        <mxCell id="d20_c_d" value="Контроль во времени:&#10;импорт выписок, прогноз&#10;SES + Monte-Carlo, дашборд" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
