        <mxCell id="d19_nva" value="Lead Time ≈ дни (ручной сбор данных пользователем — главные потери, вне ПО)" style="text;html=1;align=center;fontSize=10;fontColor=#b85450;fillColor=none;strokeColor=none;" vertex="1" parent="1">
