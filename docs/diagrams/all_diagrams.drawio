<diagram name="ГОСТ — прогноз SES + Monte-Carlo" id="forecast-gost">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="800" pageHeight="1250" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="d15_title" value="FINPILOT — Прогнозирование показателей (SES + Monte-Carlo), ГОСТ 19.701-90" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=14;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="120" y="15" width="560" height="30" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_s" value="Начало: forecast_indicator(history, h)" style="rounded=1;whiteSpace=wrap;html=1;arcSize=40;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="280" y="60" width="240" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_in" value="Ввод: ряд history,&#10;горизонт h, α = 0.3, N = 1000" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="270" y="145" width="260" height="60" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_d1" value="len(history) ≥ 2?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="240" width="180" height="100" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_fb" value="Возврат: плоский прогноз&#10;(последнее значение × h)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="560" y="255" width="200" height="70" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_p1" value="Этап 1. Сглаживание (Brown SES):&#10;Lₜ = α·yₜ + (1−α)·Lₜ₋₁&#10;уровень ряда на каждом шаге" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="380" width="220" height="80" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_p2" value="Этап 2. Оценка тренда b&#10;по сглаженным уровням&#10;(линейная аппроксимация)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="490" width="220" height="80" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_p3" value="Этап 3. Точечный прогноз&#10;ŷₜ₊ₕ = Lₜ + b·h&#10;для h шагов вперёд" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="600" width="220" height="80" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_prep" value="Подготовка: σ₀ = std(остатки),&#10;σ(h) = σ₀·√(1 + 0.5·h)" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="285" y="710" width="230" height="70" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_mc" value="Этап 4. Monte-Carlo (N = 1000):&#10;для каждой симуляции добавить шум&#10;εₕ ~ N(0, σ(h)²) к точечному прогнозу" style="shape=process;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="810" width="240" height="80" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_pc" value="Этап 5. Перцентили по ансамблю:&#10;p10, p50 (медиана), p90&#10;= доверительный интервал" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="290" y="920" width="220" height="80" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_out" value="Вывод: {point: ŷ, lower: p10,&#10;median: p50, upper: p90}" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
          <mxGeometry x="280" y="1030" width="240" height="60" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_e" value="Конец" style="rounded=1;whiteSpace=wrap;html=1;arcSize=40;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="1130" width="120" height="50" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_merge" style="ellipse;whiteSpace=wrap;html=1;fillColor=#666666;strokeColor=#666666;" vertex="1" parent="1">
          <mxGeometry x="394" y="1145" width="12" height="12" as="geometry" />
        </mxCell>

        
        <mxCell id="d15_a1" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="d15_s" target="d15_in"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d15_a2" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="d15_in" target="d15_d1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d15_a3" value="Нет" style="endArrow=block;html=1;rounded=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="d15_d1" target="d15_fb"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d15_a4" value="Да" style="endArrow=block;html=1;rounded=0;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="d15_d1" target="d15_p1"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d15_a5" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="d15_p1" target="d15_p2"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d15_a6" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="d15_p2" target="d15_p3"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d15_a7" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="d15_p3" target="d15_prep"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d15_a8" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="d15_prep" target="d15_mc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d15_a9" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="d15_mc" target="d15_pc"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d15_a10" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="d15_pc" target="d15_out"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="d15_a11" style="endArrow=block;html=1;rounded=0;" edge="1" parent="1" source="d15_out" target="d15_e"><mxGeometry relative="1" as="geometry" /></mxCell>
        
        <mxCell id="d15_a12" style="endArrow=none;html=1;rounded=0;" edge="1" parent="1" source="d15_fb" target="d15_merge"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="660" y="1151" /></Array></mxGeometry></mxCell>

      </root>
    </mxGraphModel>
  </diagram>
<diagram name="PDCA — цикл Деминга" id="pdca">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="d16_title" value="FINPILOT — Управление личными финансами как цикл PDCA (Деминга)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="130" y="20" width="590" height="30" as="geometry" />
        </mxCell>

        
        <mxCell id="d16_center" value="Непрерывное&#10;улучшение&#10;финансового&#10;состояния" style="ellipse;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="290" width="150" height="120" as="geometry" />
        </mxCell>

        
        <mxCell id="d16_plan" value="PLAN — Планируй&#10;&#10;Задать цели (goals), профиль риска,&#10;пороги Lmin/Dmax.&#10;Запустить расчёт: получить&#10;альтернативы и выбрать a*" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="90" width="290" height="120" as="geometry" />
        </mxCell>

        
        <mxCell id="d16_do" value="DO — Делай&#10;&#10;Исполнять рекомендованное&#10;распределение Rt:&#10;платить по обязательствам,&#10;пополнять резерв и цели" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="600" y="280" width="240" height="140" as="geometry" />
        </mxCell>

        
        <mxCell id="d16_check" value="CHECK — Проверяй&#10;&#10;Импортировать новую выписку.&#10;Сравнить факт. показатели&#10;(Rt, Lt, Dt, BLR) с планом&#10;на дашборде" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="280" y="490" width="290" height="120" as="geometry" />
        </mxCell>

        
        <mxCell id="d16_act" value="ACT — Воздействуй&#10;&#10;Скорректировать цели,&#10;профиль риска или пороги.&#10;Перезапустить планирование&#10;с обновлёнными данными" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=12;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="10" y="280" width="240" height="140" as="geometry" />
        </mxCell>

        
        <mxCell id="d16_e1" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#404040;strokeWidth=2;" edge="1" parent="1" source="d16_plan" target="d16_do"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="720" y="150" /><mxPoint x="720" y="280" /></Array></mxGeometry></mxCell>
        <mxCell id="d16_e2" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#404040;strokeWidth=2;" edge="1" parent="1" source="d16_do" target="d16_check"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="720" y="550" /><mxPoint x="570" y="550" /></Array></mxGeometry></mxCell>
        <mxCell id="d16_e3" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#404040;strokeWidth=2;" edge="1" parent="1" source="d16_check" target="d16_act"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="130" y="550" /><mxPoint x="130" y="420" /></Array></mxGeometry></mxCell>
        <mxCell id="d16_e4" style="endArrow=block;html=1;rounded=1;edgeStyle=orthogonalEdgeStyle;strokeColor=#404040;strokeWidth=2;" edge="1" parent="1" source="d16_act" target="d16_plan"><mxGeometry relative="1" as="geometry"><Array as="points"><mxPoint x="130" y="150" /><mxPoint x="280" y="150" /></Array></mxGeometry></mxCell>

