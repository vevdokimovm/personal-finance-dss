<diagram name="Главный pipeline СППР (ГОСТ 19.701-90)" id="main-pipeline">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="850" pageHeight="1700" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="d01_start" value="Начало" style="rounded=1;whiteSpace=wrap;html=1;arcSize=40;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="20" width="160" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_input" value="Ввод: транзакции It, Ej,&#10;обязательства O, цели G,&#10;ликвидность Bliq, профиль R" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="100" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="d01_prep" value="Этап 1. Предобработка данных&#10;(нормализация, фильтр активных целей)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="295" y="190" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_metrics" value="Этап 2. Расчёт базовых показателей&#10;CFt, Rt, Lt, Dt, BLR, Si" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="295" y="270" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_dec_rt" value="Rt &gt; 0 ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="350" y="350" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d01_deficit" value="Дефицитный бюджет:&#10;вернуть структурный диагноз&#10;(Fail-loud)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="355" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="d01_prealloc" value="Этап 4.0. Разовое закрытие близких&#10;целей из Bliq (если Σ_близкие ≤ 0.5·Bliq)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="295" y="460" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_gen" value="Этап 4. Генерация 21 альтернативы&#10;stars-and-bars, шаг 20%" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="295" y="540" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_loop" value="Для каждой альтернативы a из A" style="shape=hexagon;perimeter=hexagonPerimeter2;whiteSpace=wrap;html=1;fillColor=#e1d5e7;strokeColor=#9673a6;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="305" y="620" width="230" height="60" as="geometry" />
        </mxCell>
        <mxCell id="d01_avalanche" value="Этап 4b. Avalanche + OCR-фильтр&#10;(см. отдельную схему)" style="shape=process;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="295" y="710" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_si" value="Взвешенная обеспеченность Si&#10;(см. отдельную схему)" style="shape=process;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="295" y="790" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_recalc" value="Пересчёт Rt', Lt', Dt' для альтернативы" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="295" y="870" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_endloop" value="Альтернативы кончились?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="350" y="950" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d01_filter" value="Этап 5. Фильтрация по ограничениям&#10;Rt' ≥ 0, Lt' ≥ Lmin, Dt' ≤ Dmax" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="295" y="1060" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_dec_adm" value="A' != пусто ?" style="rhombus;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="350" y="1140" width="140" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d01_noadm" value="Нет допустимых:&#10;ослабить ограничения&#10;или пересмотр бюджета" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="600" y="1145" width="200" height="70" as="geometry" />
        </mxCell>
        <mxCell id="d01_saw" value="Этап 6. Min-max нормализация +&#10;свёртка U(a) = Σ wk·критерий (SAW)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#ffffff;strokeColor=#000000;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="295" y="1250" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_argmax" value="a* = argmax U(a)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="295" y="1330" width="250" height="50" as="geometry" />
        </mxCell>
        <mxCell id="d01_output" value="Вывод: a*, top-3 + объяснения" style="shape=parallelogram;perimeter=parallelogramPerimeter;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="310" y="1410" width="220" height="60" as="geometry" />
        </mxCell>
        <mxCell id="d01_end" value="Конец" style="rounded=1;whiteSpace=wrap;html=1;arcSize=40;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;" vertex="1" parent="1">
          <mxGeometry x="340" y="1500" width="160" height="50" as="geometry" />
