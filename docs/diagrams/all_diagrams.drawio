<diagram name="Value Proposition Canvas" id="vpc">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1220" pageHeight="510" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="d23_t" value="FINPILOT — Канва ценностного предложения (Value Proposition Canvas)" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="250" y="15" width="740" height="30" as="geometry" />
        </mxCell>
        <mxCell id="d23_vmap" value="Карта ценности (Value Map)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="80" y="70" width="420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d23_prod" value="Продукты и услуги&#10;&#10;• Веб-СППР по личным финансам&#10;• Рекомендация распределения денег&#10;• Прогноз баланса (SES + Monte-Carlo)&#10;• Дашборд показателей Rt/Lt/Dt/BLR" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="120" width="420" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d23_gain_c" value="Создатели выгод (Gain Creators)&#10;&#10;• Прозрачное объяснение каждого совета&#10;• Учёт долговой нагрузки по нормам ЦБ&#10;• Приоритизация целей по важности и срочности" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="240" width="420" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d23_pain_r" value="Обезболивающие (Pain Relievers)&#10;&#10;• Убирает «не знаю, куда деть деньги»&#10;• Не требует фин. образования&#10;• Avalanche экономит на дорогих долгах&#10;• Заменяет хаотичные решения системой" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="80" y="360" width="420" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d23_cprof" value="Профиль клиента (Customer Profile)" style="rounded=0;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=12;fontStyle=1;align=center;verticalAlign=middle;" vertex="1" parent="1">
          <mxGeometry x="720" y="70" width="420" height="40" as="geometry" />
        </mxCell>
        <mxCell id="d23_jobs" value="Задачи клиента (Customer Jobs)&#10;&#10;• Распределить зарплату с умом&#10;• Погасить кредиты оптимально&#10;• Накопить на цели&#10;• Не уйти в кассовый разрыв" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="120" width="420" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d23_gains" value="Выгоды (Gains)&#10;&#10;• Спокойствие за финансы&#10;• Видеть прогресс к целям&#10;• Уверенность в решениях&#10;• Контроль без рутины" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="240" width="420" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d23_pains" value="Боли (Pains)&#10;&#10;• Страх ошибиться с деньгами&#10;• Непонятно, гасить долг или копить&#10;• Финсоветы — «чёрный ящик»&#10;• Нет времени считать вручную" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="720" y="360" width="420" height="110" as="geometry" />
        </mxCell>
        <mxCell id="d23_fit" value="Fit / соответствие" style="endArrow=block;startArrow=block;html=1;strokeWidth=2;strokeColor=#82b366;dashed=1;" edge="1" parent="1" source="d23_vmap" target="d23_cprof">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
              <mxPoint x="610" y="90" />
            </Array>
          </mxGeometry>
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
<diagram name="SWOT-анализ" id="swot">
    <mxGraphModel dx="1100" dy="800" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1220" pageHeight="530" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />

        <mxCell id="d24_t" value="FINPILOT — SWOT-анализ" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=15;fontStyle=1;" vertex="1" parent="1">
          <mxGeometry x="350" y="15" width="540" height="30" as="geometry" />
        </mxCell>
        <mxCell id="d24_s" value="Сильные стороны (Strengths)&#10;&#10;• Объяснимость рекомендаций — ключевое отличие&#10;• Строгая математическая модель (SAW, Avalanche, MC)&#10;• Соответствие нормам ЦБ (ПДН)&#10;• Прозрачность вместо «чёрного ящика»&#10;• Гибкие профили риска" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="70" width="540" height="200" as="geometry" />
        </mxCell>
        <mxCell id="d24_w" value="Слабые стороны (Weaknesses)&#10;&#10;• Ручной импорт выписок (нет прямой банк-интеграции)&#10;• Один разработчик, ограниченный ресурс&#10;• Нет бренда и узнаваемости&#10;• Mock-данные вместо реальной агрегации&#10;• Категоризация пока на правилах (Фаза 1)" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f8cecc;strokeColor=#b85450;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="70" width="540" height="200" as="geometry" />
        </mxCell>
        <mxCell id="d24_o" value="Возможности (Opportunities)&#10;&#10;• Open Banking в РФ (планы ЦБ) — реальная интеграция&#10;• Рост спроса на фин. грамотность&#10;• Фаза 2: обучаемые правила категоризации&#10;• Мобильное приложение&#10;• Партнёрства с финтех-сервисами" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="290" width="540" height="200" as="geometry" />
        </mxCell>
        <mxCell id="d24_th" value="Угрозы (Threats)&#10;&#10;• Насыщенный рынок: Seeneco, ПланФакт, Финолог, Adesk&#10;• Встроенные инструменты банков и 1С&#10;• Регуляторные барьеры (доступ к банк. данным)&#10;• Низкая готовность платить за финсоветы&#10;• Требования к безопасности перс. данных" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#ffe6cc;strokeColor=#d79b00;fontSize=11;align=center;verticalAlign=middle;arcSize=8;" vertex="1" parent="1">
          <mxGeometry x="620" y="290" width="540" height="200" as="geometry" />
        </mxCell>
      </root>
    </mxGraphModel>
  </diagram>
