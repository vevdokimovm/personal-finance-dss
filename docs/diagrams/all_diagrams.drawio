        <mxCell id="d02_a2" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="d02_input" target="d02_dec_zero">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d02_a3" value="Да" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=11;" edge="1" parent="1" source="d02_dec_zero" target="d02_ret_all">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
