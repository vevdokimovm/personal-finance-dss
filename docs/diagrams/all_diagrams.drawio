        </mxCell>
        <mxCell id="d02_a7" value="Нет" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=11;" edge="1" parent="1" source="d02_dec_empty" target="d02_sort">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d02_a8" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="d02_sort" target="d02_init">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
