          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d02_a5" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="d02_filter" target="d02_dec_empty">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d02_a6" value="Да" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;fontSize=11;" edge="1" parent="1" source="d02_dec_empty" target="d02_npv">
          <mxGeometry relative="1" as="geometry" />
        </mxCell>
        <mxCell id="d02_a6b" style="edgeStyle=orthogonalEdgeStyle;html=1;endArrow=block;" edge="1" parent="1" source="d02_npv" target="d02_end">
          <mxGeometry relative="1" as="geometry">
            <Array as="points">
