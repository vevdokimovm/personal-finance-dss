          <mxGeometry x="520" y="120" width="240" height="80" as="geometry" />
        </mxCell>
        <mxCell id="d20_a_t" value="ANALYZE" style="text;html=1;align=left;verticalAlign=middle;fontSize=14;fontStyle=1;fillColor=none;strokeColor=none;fontColor=#7a6516;" vertex="1" parent="1">
          <mxGeometry x="565" y="135" width="160" height="25" as="geometry" />
        </mxCell>
        <mxCell id="d20_a_d" value="Анализ альтернатив:&#10;21 вариант распределения,&#10;Avalanche по дорогим долгам" style="text;html=1;align=left;verticalAlign=middle;fontSize=10;fillColor=none;strokeColor=none;" vertex="1" parent="1">
