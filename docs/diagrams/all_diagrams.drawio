          <mxGeometry x="240" y="490" width="600" height="20" as="geometry" />
        </mxCell>

        
        <mxCell id="d19_concl" value="Вывод VSM: вычислительная ценность создаётся за десятки миллисекунд; основное «время потока» — ручной ввод данных.&#10;Точка улучшения — автоматизация импорта (банковские выписки), что и реализовано через statement_parser." style="rounded=1;whiteSpace=wrap;html=1;fillColor=#f5f5f5;strokeColor=#666666;fontSize=11;align=left;verticalAlign=middle;spacingLeft=10;" vertex="1" parent="1">
          <mxGeometry x="240" y="540" width="930" height="80" as="geometry" />
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
<diagram name="DMAIC — Six Sigma" id="dmaic">
    <mxGraphModel dx="1000" dy="700" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1300" pageHeight="560" math="0" shadow="0">
      <root>
