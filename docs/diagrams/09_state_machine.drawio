        <mxCell id="t5" value="U(a) максимальна&#10;(a* первая)" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="s_rank" target="s_rec"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t6" value="U(a) не&#10;максимальна" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="s_rank" target="s_not"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t7" value="explain_alternative()&#10;gains / costs / insight" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="s_rec" target="s_exp"><mxGeometry relative="1" as="geometry" /></mxCell>
