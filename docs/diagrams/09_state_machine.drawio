        <mxCell id="t1" value="evaluate_alternative()&#10;Avalanche + Si + пересчёт Rt'/Lt'/Dt'" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="s_gen" target="s_eval"><mxGeometry relative="1" as="geometry" /></mxCell>
        <mxCell id="t2" value="проходит фильтр&#10;Rt'≥0 ∧ Lt'≥Lmin ∧ Dt'≤Dmax" style="endArrow=block;html=1;edgeStyle=orthogonalEdgeStyle;rounded=0;fontSize=10;labelBackgroundColor=#ffffff;" edge="1" parent="1" source="s_eval" target="s_adm"><mxGeometry relative="1" as="geometry" /></mxCell>
