        </mxCell>

        <!-- Lifelines -->
        <mxCell id="l_user" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="85" y="120" as="sourcePoint" /><mxPoint x="85" y="720" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="l_api" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="105" as="sourcePoint" /><mxPoint x="280" y="720" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="l_sp" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="520" y="105" as="sourcePoint" /><mxPoint x="520" y="720" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="l_p" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="765" y="105" as="sourcePoint" /><mxPoint x="765" y="720" as="targetPoint" /></mxGeometry></mxCell>
        <mxCell id="l_db" style="endArrow=none;dashed=1;html=1;strokeColor=#999999;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="965" y="105" as="sourcePoint" /><mxPoint x="965" y="720" as="targetPoint" /></mxGeometry></mxCell>

        <!-- Messages -->
