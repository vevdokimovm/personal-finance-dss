        <mxCell id="m7" value="сохранено" style="endArrow=open;html=1;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="965" y="580" as="sourcePoint" /><mxPoint x="280" y="580" as="targetPoint" /></mxGeometry></mxCell>

        <mxCell id="m8" value="{imported: N, transactions}" style="endArrow=open;html=1;dashed=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="280" y="625" as="sourcePoint" /><mxPoint x="85" y="625" as="targetPoint" /></mxGeometry></mxCell>

        <mxCell id="f_user" value="Пользователь" style="shape=umlActor;verticalLabelPosition=bottom;labelBackgroundColor=#ffffff;verticalAlign=top;html=1;fillColor=#dae8fc;strokeColor=#6c8ebf;fontSize=11;" vertex="1" parent="1">
