        <mxCell id="m3" value="выбор парсера по bank_id (tinkoff/sber/universal)" style="endArrow=block;html=1;fontSize=11;labelBackgroundColor=#ffffff;" edge="1" parent="1"><mxGeometry relative="1" as="geometry"><mxPoint x="520" y="230" as="sourcePoint" /><mxPoint x="765" y="230" as="targetPoint" /></mxGeometry></mxCell>

