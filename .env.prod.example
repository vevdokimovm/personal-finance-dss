# ════════════════════════════════════════════════════════════════════════════
# FINPILOT — боевые переменные окружения (production)
# ════════════════════════════════════════════════════════════════════════════
# Скопируй в .env РЯДОМ с docker-compose.prod.yml на сервере и заполни.
# .env НИКОГДА не коммитить (проверь .gitignore).
#
# Сгенерировать стойкие секреты:
#   openssl rand -hex 32      # для JWT_SECRET, TOKEN_ENCRYPTION_KEY
#   openssl rand -hex 24      # для ADMIN_API_KEY, POSTGRES_PASSWORD
#
# Без обязательных секретов приложение НЕ стартует (fail-loud) — это by design.
# ════════════════════════════════════════════════════════════════════════════

# ── Режим ───────────────────────────────────────────────────────────────────
ENVIRONMENT=production

# ── Домен (для nginx и CORS) ────────────────────────────────────────────────
# Без протокола, как в DNS A-записи.
DOMAIN=finpilot.ru

# ── База данных ─────────────────────────────────────────────────────────────
# Пароль БД. ОДИН источник правды: DATABASE_URL для приложения собирается из
# него в docker-compose.prod.yml (postgresql+psycopg://finpilot:${POSTGRES_PASSWORD}@db:5432/finpilot).
POSTGRES_PASSWORD=

# ── Безопасность входа ──────────────────────────────────────────────────────
JWT_SECRET=
JWT_ALGORITHM=HS256
JWT_TTL_HOURS=168
AUTH_COOKIE_NAME=fp_access
COOKIE_SECURE=true
LOGIN_MAX_ATTEMPTS=5
LOGIN_LOCKOUT_MINUTES=15
PASSWORD_RESET_TTL_HOURS=1

# Ключ шифрования PII (display_name, комментарии) — Fernet/AES.
# Обязателен в проде, иначе шифрование at-rest не работает корректно.
TOKEN_ENCRYPTION_KEY=

# Админ-ключ для cron-эндпоинтов (/notifications/run, /fx/refresh).
ADMIN_API_KEY=

# ── CORS ────────────────────────────────────────────────────────────────────
# Боевой origin под HTTPS. Подставь свой домен.
CORS_ORIGINS=https://finpilot.ru,https://www.finpilot.ru

# ── Rate limiting ───────────────────────────────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ── Почта (P0.2 — без неё не работают верификация, сброс пароля, уведомления) ─
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@finpilot.ru
SMTP_USE_TLS=true

# ── Наблюдаемость ───────────────────────────────────────────────────────────
SENTRY_DSN=
LOG_LEVEL=INFO
LOG_JSON=true

# ── Валюта по умолчанию ─────────────────────────────────────────────────────
DEFAULT_BASE_CURRENCY=RUB

# ── Юридические реквизиты (152-ФЗ) ──────────────────────────────────────────
LEGAL_OPERATOR_NAME=ООО «ФИНПАЙЛОТ»
LEGAL_OPERATOR_INN=
LEGAL_OPERATOR_ADDRESS=
LEGAL_CONTACT_EMAIL=support@finpilot.ru
LEGAL_DOC_DATE=
LEGAL_DATA_RETENTION_MONTHS=6
LEGAL_DETAILS_CONFIRMED=true

# ── Бэкапы (для scripts/backup_db.sh на хосте) ──────────────────────────────
BACKUP_RETENTION_DAYS=14

# ── Cron (для scripts/cron_*.sh — дёргают приложение по loopback) ───────────
FINPILOT_BASE_URL=http://127.0.0.1:8000

# ── Интеграции вне основного скоупа (оставь пустыми) ────────────────────────
B2B_API_KEYS=
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
