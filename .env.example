# Окружение: development | production
ENVIRONMENT=development

# База данных: SQLite (локально) или PostgreSQL (Docker)
DATABASE_URL=sqlite:///./finpilot.db
# DATABASE_URL=postgresql+psycopg://finpilot:finpilot@db:5432/finpilot

# CORS — домены фронтенда через запятую
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000

# Rate-limit на чувствительные эндпоинты
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60
