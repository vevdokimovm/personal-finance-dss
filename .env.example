# ── Окружение ────────────────────────────────────────────────────────
ENVIRONMENT=development            # development | production

# ── База данных ──────────────────────────────────────────────────────
# Локально — SQLite; для прода/Docker — PostgreSQL (схема по ER: uuid, numeric)
DATABASE_URL=sqlite:///./finpilot.db
# DATABASE_URL=postgresql+psycopg://finpilot:finpilot@db:5432/finpilot

# ── CORS / rate-limit (INFRA-12) ─────────────────────────────────────
CORS_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_WINDOW_SECONDS=60

# ── Аутентификация JWT (INFRA-06, NFR-05) ────────────────────────────
# ОБЯЗАТЕЛЬНО задайте свой секрет в проде (минимум 32 символа).
# Сгенерировать: openssl rand -hex 32
# В production приложение НЕ стартует с этим дефолтом или секретом короче 32 символов.
JWT_SECRET=dev-insecure-secret-change-me-in-production-env-32b
JWT_ALGORITHM=HS256
JWT_TTL_HOURS=168
AUTH_COOKIE_NAME=fp_access

# ── Защита логина от перебора (P1.2, NFR-05) ─────────────────────────
LOGIN_MAX_ATTEMPTS=5               # неудачных попыток до блокировки аккаунта
LOGIN_LOCKOUT_MINUTES=15          # длительность блокировки

# ── Secure-cookie (HTTPS) ────────────────────────────────────────────
# false — кука работает по HTTP (локалка/Docker по http://localhost).
# true  — только когда фронт реально обслуживается по HTTPS (прод за reverse-proxy).
# В production COOKIE_SECURE=false приведёт к падению старта (fail-loud).
COOKIE_SECURE=false

# ── Запуск через Docker (docker-compose.yml) ─────────────────────────
# Прод (по умолчанию): ENVIRONMENT=production, COOKIE_SECURE=true, обязателен JWT_SECRET,
#   контейнер web ставится за HTTPS reverse-proxy (nginx/traefik/Caddy → web:8000).
# Локальный HTTP-тест через Docker: в .env рядом с docker-compose.yml задайте
#   ENVIRONMENT=development и COOKIE_SECURE=false (иначе вход по http не сработает).

# ── Мультивалюта (FR-19) ─────────────────────────────────────────────
DEFAULT_BASE_CURRENCY=RUB

# ── B2B-портал /v1/analyze (FR-23) ───────────────────────────────────
# Пусто = эндпоинт отключён (отдаёт 404). Ключи через запятую.
B2B_API_KEYS=

# ── Plaid open banking (FR-18, INFRA-16/17) — только US/CA ───────────
# Пусто = Plaid-маршруты отключены (404). Для РФ не используется (KEEP-06).
PLAID_CLIENT_ID=
PLAID_SECRET=
PLAID_ENV=sandbox
# Fernet-ключ шифрования Plaid-токенов (INFRA-17). Пусто = derive из JWT_SECRET.
TOKEN_ENCRYPTION_KEY=

# ── Почта (подтверждение email) ──────────────────────────────────────
# Пусто = почта выключена, подтверждение идёт по ссылке (тост в интерфейсе).
# Для продакшена: транзакционный сервис с верифицированным доменом (SPF/DKIM/DMARC).
# Пример для NotiSend / Sendsay / DashaMail (РФ, 152-ФЗ) — креды берутся в их ЛК:
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@ваш-домен.ru
SMTP_USE_TLS=true

# ── Юридические реквизиты оператора (P1.1, 152-ФЗ) ───────────────────
# Подставляются в опубликованные документы (/legal/*) и footer из одного места.
# Пока LEGAL_DETAILS_CONFIRMED=false ИЛИ пусты ИНН/адрес — на юр-страницах виден
# баннер «документ в стадии оформления» (страховка от публикации сырого документа).
#
# Чтобы убрать баннер и опубликовать боевые документы:
#   1) зарегистрировать юрлицо/ИП → получить ИНН и адрес;
#   2) заполнить поля ниже реальными данными;
#   3) пройти юридическое ревью текстов профильным юристом по ПДн;
#   4) выставить LEGAL_DETAILS_CONFIRMED=true.
#
# ИНН/адрес НЕ выдумывать — фейковые реквизиты в юр-документе недопустимы.
LEGAL_OPERATOR_NAME=ООО «ФИНПАЙЛОТ»
LEGAL_OPERATOR_INN=
LEGAL_OPERATOR_ADDRESS=
LEGAL_CONTACT_EMAIL=support@finpilot.app
LEGAL_DOC_DATE=
LEGAL_DATA_RETENTION_MONTHS=6
LEGAL_DETAILS_CONFIRMED=false
